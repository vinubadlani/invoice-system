--
-- Name: expenses Users can create expenses for own businesses; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can create expenses for own businesses" ON public.expenses FOR INSERT WITH CHECK ((business_id IN ( SELECT businesses.id
   FROM public.businesses
  WHERE (businesses.user_id = auth.uid()))));


--
-- Name: sales_items Users can create sales_items for own businesses; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can create sales_items for own businesses" ON public.sales_items FOR INSERT WITH CHECK ((business_id IN ( SELECT businesses.id
   FROM public.businesses
  WHERE (businesses.user_id = auth.uid()))));


--
-- Name: bank_accounts Users can delete bank_accounts for their businesses; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can delete bank_accounts for their businesses" ON public.bank_accounts FOR DELETE USING ((business_id IN ( SELECT businesses.id
   FROM public.businesses
  WHERE (businesses.user_id = auth.uid()))));


--
-- Name: expenses Users can delete expenses of own businesses; Type: POLICY; Schema: public; Owner: postgres
--

